OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=

# auto: use real OpenAI calls when OPENAI_API_KEY exists, otherwise deterministic mock mode.
# true: force mock mode. false: force real API calls.
AUDIO_FIRST_MOCK_MODE=auto
# true: skip expensive reasoning-model prediction/verification/synthesis calls.
# Useful for local JoyAI verification and quick product feedback loops.
AUDIO_FIRST_FAST_MODE=false

# Optional executable overrides. Leave blank to use PATH.
FFMPEG_PATH=
FFPROBE_PATH=

DATA_DIR=./data
TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize
TRANSCRIBE_FALLBACK_MODEL=gpt-4o-transcribe

# Optional: set only when your provider exposes Chat Completions audio input
# with content type input_audio. Most text/image-only proxies should leave it blank.
AUDIO_CHAT_TRANSCRIBE_MODEL=

VISION_MODEL=gpt-5.4-mini
# openai: use the configured cloud/OpenAI-compatible vision model.
# joyai: use local JoyAI-VL-Interaction adapter for targeted frame verification.
# auto: try JoyAI first, then fall back to the cloud vision model.
VISION_PROVIDER=openai
JOYAI_API_BASE=http://127.0.0.1:8070/v1
JOYAI_API_KEY=EMPTY
JOYAI_MODEL=JoyAI-VL-Interaction-Preview
JOYAI_TIMEOUT_SECONDS=30
# clips: default static-video path; pass short MP4 clips to JoyAI video_url for temporal context.
# frames: force single-frame image verification. auto: only use clips for temporal questions.
# Live moderation still uses frame verification so evidence capture stays cheap and stable.
JOYAI_INPUT_MODE=clips
JOYAI_CLIP_SECONDS=4
# true: use 2s clips for static checks and JOYAI_CLIP_SECONDS for temporal/action checks.
JOYAI_ADAPTIVE_CLIP_SECONDS=true
JOYAI_CLIP_WIDTH=640
JOYAI_MAX_CLIPS_PER_JOB=4
REASONING_MODEL=gpt-5.5
# Optional for GPT-5-style Responses models. Known xiaoice values include none,
# low, medium, high, and xhigh. Leave blank when the provider does not support it.
REASONING_EFFORT=
# Optional low-latency model for chat follow-up QA. Defaults to REASONING_MODEL.
FOLLOWUP_MODEL=gpt-5.4-mini
FOLLOWUP_TIMEOUT_SECONDS=20
FOLLOWUP_MAX_CHUNKS=12
WEB_SEARCH_ENABLED=true
# duckduckgo works without a key. For a custom JSON search endpoint, set WEB_SEARCH_PROVIDER and WEB_SEARCH_BASE_URL.
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_BASE_URL=
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=5
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=1

# 静态视频解析不再限制最短/最长时长；长视频会按关键帧预算采样，但转写耗时会随时长增加。
MIN_VIDEO_SECONDS=0
MAX_VIDEO_SECONDS=0
MAX_REFINEMENT_ROUNDS=1
REFINEMENT_SAMPLES_PER_WINDOW=1
MAX_KEYFRAMES=6
ENHANCED_INITIAL_KEYFRAMES=4
FAST_MAX_TIMELINE_EVENTS=12
FAST_MAX_KEYFRAMES=12
FAST_SECONDS_PER_FRAME=120
LIVE_WINDOW_SECONDS=2
LIVE_MAX_SEGMENTS=0
LIVE_SEGMENT_TIMEOUT_SECONDS=18
LIVE_FAST_CAPTURE=true
LIVE_FRAME_WIDTH=640
KEYFRAME_STRATEGY=enhanced
CANDIDATE_SAMPLE_FPS=3
CANDIDATE_MAX_PER_EVENT=2
CANDIDATE_HASH_MIN_DISTANCE=4
VISION_BATCH_SIZE=3

# Some Douyin pages require fresh browser cookies for yt-dlp.
# Export cookies as Netscape cookies.txt and set one of these, or let yt-dlp read a closed browser profile.
DOUYIN_COOKIES_FILE=
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=

# When true, model/API failures fall back to deterministic local heuristics so
# the video pipeline can still be tested end-to-end.
ALLOW_MODEL_FALLBACK=true

# Optional local transcription fallback when the configured API/proxy does not
# support /audio/transcriptions. Use a local faster-whisper model directory to
# avoid downloading weights during a job.
LOCAL_TRANSCRIBE_FALLBACK=true
LOCAL_TRANSCRIBE_FIRST=false
LOCAL_TRANSCRIBE_MODEL=data/models/faster-whisper-base
